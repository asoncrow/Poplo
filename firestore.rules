rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Sites
    // ===============================================================
    match /sites/{siteId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && hasRequiredFields(['userId', 'siteName', 'siteUrl', 'createdAt']);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // ===============================================================
    // Site Configs
    // ===============================================================
    match /site_configs/{configId} {
      // Publicly readable so the ticker script can fetch it
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(request.resource.data.siteId)).data.userId) &&
                    hasRequiredFields(['siteId', 'updatedAt']);
                    
      allow update: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(resource.data.siteId)).data.userId) &&
                    request.resource.data.siteId == resource.data.siteId;
                    
      allow delete: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(resource.data.siteId)).data.userId);
    }

    // ===============================================================
    // Notification Events
    // ===============================================================
    match /notification_events/{eventId} {
      // Publicly readable so the ticker script can fetch it
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(request.resource.data.siteId)).data.userId) &&
                    hasRequiredFields(['siteId', 'createdAt']);
                    
      allow update: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(resource.data.siteId)).data.userId) &&
                    request.resource.data.siteId == resource.data.siteId;
                    
      allow delete: if isAuthenticated() && 
                    isOwner(get(/databases/$(database)/documents/sites/$(resource.data.siteId)).data.userId);
    }
  }
}
